{
  "manifest_version": 3,
  "name": "Green Giant",
  "short_name": "Green Giant",
  "version": "0.1.0",
  "description": "Realtime clean video enhancement for YouTube.",
  "permissions": ["storage"],
  "host_permissions": ["https://www.youtube.com/*"],
  "minimum_chrome_version": "88",
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["content.bundle.js"],
      "css": ["styles.css"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Green Giant"
  },
  "web_accessible_resources": [
    {
      "matches": ["https://www.youtube.com/*"],
      "resources": ["icons/*.png"]
    }
  ]
}
